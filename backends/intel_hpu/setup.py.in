import os
import re
from setuptools import setup, Distribution
import shutil

packages = []
package_data = {}

class BinaryDistribution(Distribution):
    def has_ext_modules(self):
        return True

def write_custom_op_api_py(filename='python/paddle_custom_device/intel_hpu/ops.py', libname='python/paddle_custom_device/libpaddle-intel-hpu.so'):
    import os
    os.environ['CUSTOM_DEVICE_ROOT']=''
    import sys
    import paddle
    op_names = paddle.utils.cpp_extension.extension_utils.load_op_meta_info_and_register_op(libname)
    api_content = [paddle.utils.cpp_extension.extension_utils._custom_api_content(op_name) for op_name in op_names]
    dirname = os.path.dirname(filename)
    if not os.path.exists(dirname):
        os.makedirs(dirname)
    with open(filename, 'w') as f:
        f.write('''# THIS FILE IS GENERATED FROM PADDLEPADDLE SETUP.PY
#
import paddle
import os
for lib in os.listdir(os.getenv("CUSTOM_DEVICE_ROOT")):
    if lib.endswith(".so"):
        paddle.utils.cpp_extension.extension_utils.load_op_meta_info_and_register_op(
            lib
        )
''')
        f.write('\n\n'.join(api_content))


# Common version information template
VERSION_TEMPLATE = '''
full_version  = '@PADDLE_VERSION@'
synapse_version  = @SYNAPSE_VERSION@
git_commit_id = '@GIT_HASH@'
custom_op_git_commit_id = '@CUSTOM_OP_GIT_HASH@'

__all__ = ['version']

def version():
    """Get the version info of paddle custom npu

    Returns:
        version: version of paddle custom npu
        commit: the commit id of paddle custom npu
        cann: the cann version of paddle custom npu

    Examples:
        .. code-block:: python

            import paddle_custom_device

            paddle_custom_device.intel_hpu.version()
            # version: 2.5.0
            # commit: b1539a921dbabf708807ebedb2671fa7bd3fd2f9
            # synapse: 1.17.0
    """
    print('version:', full_version)
    print('commit:', git_commit_id)
    print('custom_op commit:', custom_op_git_commit_id)
    print('synapse:', synapse_version)
    return {'version': full_version, 'commit': git_commit_id, 'custom_op commit': custom_op_git_commit_id, 'synapse': synapse_version}
'''

# Common header template
HEADER_TEMPLATE = '''# THIS FILE IS GENERATED FROM PADDLEPADDLE SETUP.PY
#
from .ops import *
'''
def write_default_version_py(filename='python/paddle_custom_device/intel_hpu/__init__.py'):
    dirname = os.path.dirname(filename)
    if not os.path.exists(dirname):
        os.makedirs(dirname)
    cnt = HEADER_TEMPLATE + VERSION_TEMPLATE

    with open(filename, 'w') as f:
        f.write(cnt)
    print(f"Generated default version file: {filename}")

def write_version_py(filename='python/paddle_custom_device/intel_hpu/__init__.py'):
    """
    Rewrite __init__.py file with the following modifications:
    1. Remove lines containing 'paddle_custom_device.intel_hpu.ops import'
    2. Insert generated header before the first 'from xxx import' statement
    3. Add version information and functions at the end of the file
    """

    if not os.path.exists(filename):
        print(f"File {filename} does not exist, to use defual write_version")
        write_default_version_py()
        return

    # Read original file content
    with open(filename, 'r', encoding='utf-8') as f:
        lines = f.readlines()

    # Filter out lines containing paddle_custom_device.intel_hpu.ops import
    filtered_lines = []
    for line in lines:
        if 'paddle_custom_device.intel_hpu.ops import' not in line:
            filtered_lines.append(line)

    # Find the position of the first 'from xxx import' statement
    first_import_index = -1
    for i, line in enumerate(filtered_lines):
        stripped_line = line.strip()
        # Match patterns like 'from .xxx import *' or 'from xxx import *'
        if re.match(r'^from\s+(\.\w+|\w+)\s+import\s+\*', stripped_line):
            first_import_index = i
            break

    # Prepare header to be inserted
    header = HEADER_TEMPLATE

    # Build new file content
    new_content = []

    # Add copyright header and other content before the first import statement
    if first_import_index != -1:
        # Add all lines from beginning to just before the first import
        new_content.extend(filtered_lines[:first_import_index])
        # Insert generated header before the first import
        new_content.append(header)
        # Add remaining lines (including the first import)
        new_content.extend(filtered_lines[first_import_index:])
    else:
        # If no import statements found, add all filtered lines and append header at the end
        new_content.extend(filtered_lines)
        new_content.append('\n' + header)

    # Add version information at the end of file
    footer = VERSION_TEMPLATE

    new_content.append(footer)

    # Write modified content back to file
    with open(filename, 'w', encoding='utf-8') as f:
        f.writelines(new_content)

    print(f"Successfully rewritten {filename}")

    # Display processing results
    print("\nProcessed content preview:")
    with open(filename, 'r', encoding='utf-8') as f:
        content = f.read()
        print(content)

    print(f"Generated {filename} done")

def write_init_py(filename='python/paddle_custom_device/__init__.py'):
    dirname = os.path.dirname(filename)
    if not os.path.exists(dirname):
        os.makedirs(dirname)
    cnt = '''
#
# THIS FILE IS GENERATED FROM PADDLEPADDLE SETUP.PY
#
from . import intel_hpu # noqa: F401

__all__ = [  # noqa
    'intel_hpu',
]

'''
    with open(filename, 'a+') as f:
        f.write(cnt)

def copy_paddlenlp_ops_files(source_path='../custom_ops/python/paddlenlp_ops', target_path='python/paddle_custom_device/intel_hpu'):
    if not os.path.exists(source_path):
        print(f"Source path {source_path} does not exist")
        return

    try:
        os.makedirs(target_path, exist_ok=True)
        # to check whether the dir can be accessed
        if not os.access(source_path, os.R_OK):
            print(f"Cannot read source directory: {source_path}")
            return

        for file in os.listdir(source_path):
            #all .py file including the '__init__.py' file will be copied into target_path
            if file.endswith('.py'):
                source_file = os.path.join(source_path, file)

                #to check file can be read
                if not os.access(source_file, os.R_OK):
                    print(f"Cannot read file: {source_file}")
                    continue

                target_file = os.path.join(target_path, file)

                try:
                    # to open and read source file
                    with open(source_file, 'r') as f:
                        content = f.read()

                    # to do modify
                    modified_content = content.replace('import paddlenlp_ops', 'import paddle_custom_device.intel_hpu as paddlenlp_ops')
                    modified_content = modified_content.replace('from paddlenlp_ops import', 'from paddle_custom_device.intel_hpu import')

                    # write to the target file
                    with open(target_file, 'w') as f:
                        f.write(modified_content)

                    print(f"Processed {file}")

                except PermissionError:
                    print(f"Permission denied when accessing {source_file}")
                except Exception as e:
                    print(f"Error processing {file}: {e}")

    except Exception as e:
        print(f"General error: {e}")

copy_paddlenlp_ops_files()
write_custom_op_api_py()
write_version_py()
write_init_py()

setup(
    name = '@CMAKE_PROJECT_NAME@',
    version='@PLUGIN_VERSION@',
    description='PaddlePaddle INTEL HPU plugin',
    long_description='',
    long_description_content_type="text/markdown",
    author_email="Paddle-better@baidu.com",
    maintainer="PaddlePaddle",
    maintainer_email="Paddle-better@baidu.com",
    project_urls={},
    license='Apache Software License',
    packages= [
        'paddle_custom_device',
        'paddle_custom_device.intel_hpu',
    ],
    include_package_data=True,
    package_data = {
        '': ['*.so', '*.h', '*.py', '*.hpp'],
    },
    package_dir = {
        '': 'python',
    },
    zip_safe=False,
    distclass=BinaryDistribution,
    entry_points={
        'console_scripts': [
        ]
    },
    classifiers=[
    ],
    keywords='PaddlePaddle INTEL HPU plugin',
)
